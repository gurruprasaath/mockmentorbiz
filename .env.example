#############################################
# MockMentorBiz Environment (Single Source of Truth)
#############################################
# Copy this file to `.env` and fill in your values.
# NEVER commit your real .env file.

#############################################
# AI / Speech API Keys
#############################################
OPENAI_API_KEY=your-openai-api-key
GROQ_API_KEY=your-groq-api-key
GROQ_ANSWER=your-groq-answer-key
GROQ_DOMAIN=your-groq-domain-key
GROQ_EVALUATE=your-groq-evaluate-key
GROQ_RESUME=your-groq-resume-key

# Groq model settings
GROQ_MODEL_ANSWER=llama-3.3-70b-versatile
GROQ_MODEL_EVALUATE=llama-3.3-70b-versatile
GROQ_MODEL_QUESTION=llama-3.3-70b-versatile
GROQ_MODEL_RESUME=llama-3.3-70b-versatile
GROQ_MAX_TOKENS_EVALUATE=100
GROQ_TEMPERATURE_ANSWER=0.0
GROQ_TEMPERATURE_EVALUATE=0.0
GROQ_TEMPERATURE_QUESTION=0.0
GROQ_TEMPERATURE_RESUME=0.7

# Optional TTS providers
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id
ELEVENLABS_MODEL_ID=eleven_monolingual_v1
MURF_API_KEY=your-murf-api-key

# Whisper
WHISPER_MODEL=whisper-large-v3.en
WHISPER_TEMPERATURE=0.0

#############################################
# Backend auth + bootstrap secrets
#############################################
SECRET_KEY=change-me-use-a-long-random-string
JWT_SECRET=change-me-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

SUPER_ADMIN_SECRET=change-me
SUPERADMIN_BOOTSTRAP_ALLOW_REMOTE=false

OWNER_BOOTSTRAP_SECRET=change-me
OWNER_BOOTSTRAP_ALLOW_REMOTE=false

# Optional: seed the first platform Owner automatically on first run
OWNER_SEED_ON_STARTUP=false
OWNER_SEED_EMAIL=
OWNER_SEED_USERNAME=
OWNER_SEED_PASSWORD=
OWNER_SEED_FULL_NAME=

#############################################
# Database
#############################################
DATABASE_URL=mysql+pymysql://root:yourpassword@127.0.0.1:3306/mockmentorbiz
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=yourpassword
MYSQL_DATABASE=mockmentorbiz
MYSQL_PORT=3306
AUTO_CREATE_DB=true
SQL_ECHO=false
INIT_DATABASE=false

#############################################
# Server
#############################################
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO
TEST_MODE=false

#############################################
# Uploads
#############################################
UPLOADS_DIR=uploads
MAX_FILE_SIZE=10485760

#############################################
# CORS
#############################################
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://localhost:8081

#############################################
# Frontend (Vite)
#############################################
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
VITE_APP_NAME=MockMentorBiz
VITE_APP_VERSION=1.0.0
VITE_ENABLE_VOICE_RECORDING=true
VITE_ENABLE_VIDEO_PROCTORING=true
VITE_ENABLE_ANALYTICS=true
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info
VITE_ALLOWED_FILE_TYPES=.pdf,.doc,.docx
VITE_ENABLE_PROCTORING=true
VITE_ENABLE_VOICE_FEATURES=true
VITE_MAX_FILE_SIZE=10485760
